{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm --workspace=@kroni/shared run build",
    "dev": "phase run \"next dev --webpack --port 3001\"",
    "dev:turbo": "phase run \"next dev --turbopack --port 3001\"",
    "prebuild": "npm --workspace=@kroni/shared run build",
    "build": "phase run \"next build\"",
    "start": "phase run \"next start\"",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
}
