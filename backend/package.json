{
  "name": "@kroni/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:jobs": "tsx watch src/jobs/runner.ts",
    "build": "tsc",
    "start": "node --enable-source-maps dist/server.js",
    "start:jobs": "node --enable-source-maps dist/jobs/runner.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/tests/**/*.test.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.4",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.1",
    "@kroni/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.27.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "expo-server-sdk": "^3.13.0",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "svix": "^1.42.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
