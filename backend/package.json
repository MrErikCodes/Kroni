{
  "name": "@kroni/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "phase run \"tsx watch src/server.ts\"",
    "dev:jobs": "phase run \"tsx watch src/jobs/runner.ts\"",
    "prebuild": "npm --workspace=@kroni/shared run build",
    "build": "phase run tsc",
    "release:sentry": "phase run \"node scripts/sentry-release.mjs\"",
    "start": "phase run \"node --enable-source-maps dist/server.js\"",
    "start:jobs": "phase run \"node --enable-source-maps dist/jobs/runner.js\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "phase run \"tsx src/db/migrate.ts\"",
    "db:studio": "phase run \"drizzle-kit studio\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ngrok": "ngrok http http://localhost:3000 --domain=square-logically-shark.ngrok-free.app",
    "test": "phase run \"tsx --import ./src/tests/_env.ts --test --test-concurrency=1 src/tests/health.test.ts src/tests/pairing.test.ts src/tests/balance.test.ts src/tests/allowance.test.ts src/tests/log-completion.test.ts\""
  },
  "dependencies": {
    "@clerk/backend": "^1.21.4",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.1",
    "@kroni/shared": "*",
    "@sentry/node": "^10.50.0",
    "bcryptjs": "^2.4.3",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "expo-server-sdk": "^3.13.0",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "svix": "^1.42.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sentry/cli": "^2.55.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1"
  }
}
