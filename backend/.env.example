NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Postgres 17
DATABASE_URL=postgres://kroni:kroni@localhost:5432/kroni_dev

# Redis 7.4
REDIS_URL=redis://localhost:6379

# Clerk (parent auth)
CLERK_SECRET_KEY=sk_test_REPLACE
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE
CLERK_WEBHOOK_SECRET=whsec_REPLACE

# Kid JWT (HS256). Generate fresh: openssl rand -hex 32
KID_JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32

# Expo push (optional in dev, required for sending pushes)
EXPO_ACCESS_TOKEN=

APP_TIMEZONE=Europe/Oslo
APP_PUBLIC_URL=https://api.kroni.no
APP_WEBSITE_URL=https://kroni.no
