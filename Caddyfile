# Kroni Caddy 2 reverse-proxy config — place at /etc/caddy/Caddyfile on the server.
# Caddy auto-provisions Let's Encrypt certs for each hostname.

api.kroni.no {
    reverse_proxy localhost:3000
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
    }

    # Cap upload size (no file uploads in v1, but defend in depth).
    request_body {
        max_size 1MB
    }

    log {
        output file /var/log/caddy/api.kroni.no.log {
            roll_size 50mb
            roll_keep 14
        }
    }
}

kroni.no, www.kroni.no, kroni.se, www.kroni.se, kroni.dk, www.kroni.dk {
    # Strip www. → apex (per-TLD).
    @wwwNo host www.kroni.no
    redir @wwwNo https://kroni.no{uri} permanent
    @wwwSe host www.kroni.se
    redir @wwwSe https://kroni.se{uri} permanent
    @wwwDk host www.kroni.dk
    redir @wwwDk https://kroni.dk{uri} permanent

    reverse_proxy localhost:3001 {
        # Pass the original Host through so Next's proxy.ts can pick the
        # right default locale per country domain.
        header_up Host {host}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
    }
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output file /var/log/caddy/kroni.web.log {
            roll_size 50mb
            roll_keep 14
        }
    }
}
